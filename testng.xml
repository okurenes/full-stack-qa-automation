<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Full-Stack QA Automation Suite" verbose="1" parallel="classes" thread-count="3">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="UI Tests - SauceDemo E-Commerce">
        <groups>
            <run>
                <include name="ui"/>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.qa.automation.ui.tests.LoginTest"/>
            <class name="com.qa.automation.ui.tests.InventoryTest"/>
            <class name="com.qa.automation.ui.tests.CheckoutTest"/>
        </classes>
    </test>

    <test name="API Tests - ReqRes REST API">
        <groups>
            <run>
                <include name="api"/>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.qa.automation.api.tests.UserApiTest"/>
            <class name="com.qa.automation.api.tests.AuthApiTest"/>
            <class name="com.qa.automation.api.tests.ResourceApiTest"/>
        </classes>
    </test>

    <test name="BDD Tests - Cucumber Scenarios">
        <classes>
            <class name="com.qa.automation.bdd.runner.CucumberRunner"/>
        </classes>
    </test>

    <test name="Performance Tests - Load &amp; Stress">
        <classes>
            <class name="com.qa.automation.performance.LoadTest"/>
        </classes>
    </test>

</suite>
